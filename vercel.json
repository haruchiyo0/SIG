{
  "cleanUrls": true,
  "headers": [
    {
      "source": "/data/(.*).geojson",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/geo+json; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=300"
        }
      ]
    }
  ]
}
